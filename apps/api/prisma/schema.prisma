// TicketSystem v1 — Master Schema (Prisma 6)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  ADMIN
  DEPARTMENT_USER
  STUDIO_USER
}

enum Department {
  HR
  OPERATIONS
  MARKETING
  RETAIL
}

enum TicketStatus {
  NEW
  TRIAGED
  IN_PROGRESS
  WAITING_ON_REQUESTER
  WAITING_ON_VENDOR
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

/// Stage 4: LOCKED/READY for workflow; DONE/SKIPPED satisfy dependencies.
/// Stage 2 cleanup: BLOCKED removed — blocking is ticket-level only (WAITING_ON_*).
enum SubtaskStatus {
  LOCKED
  READY
  IN_PROGRESS
  DONE
  SKIPPED
}

enum NotificationEventType {
  TICKET_CREATED
  TICKET_ASSIGNED
  TICKET_REASSIGNED
  TICKET_STATUS_CHANGED
  TICKET_RESOLVED
  TICKET_CLOSED
  COMMENT_ADDED
  MENTION_IN_COMMENT
  SUBTASK_ASSIGNED
  SUBTASK_COMPLETED
  SUBTASK_BECAME_READY
  ATTACHMENT_ADDED
  TICKET_SLA_BREACHED
}

enum DeliveryChannel {
  EMAIL
  IN_APP
  TEAMS
}

enum DeliveryStatus {
  PENDING
  SENT
  FAILED
  DEAD_LETTERED
}

enum AuditAction {
  CREATED
  UPDATED
  DELETED
  STATUS_CHANGED
  ASSIGNED
  REASSIGNED
  COMMENTED
  ATTACHMENT_ADDED
  SUBTASK_CREATED
  SUBTASK_UPDATED
  SUBTASK_COMPLETED
}

/// Admin invite-only provisioning lifecycle
enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

// Email-triggered assembly automation (Stage 1+)
enum VendorOrderState {
  ORDER_CONFIRMED
  REVIEW_REQUIRED
}

enum DeliveryEventStatus {
  DELIVERY_RECORDED
  ASSEMBLY_TRIGGERED
  COMPLETE_NO_ASSEMBLY
  REVIEW_REQUIRED
}

enum AssemblyTriggerMatchMode {
  SUBSTRING
  EXACT_OR_FUZZY_ALIAS
}

enum EmailAutomationReviewReason {
  PENDING_ORDER_MATCH
  NO_STUDIO_MATCH
  LOW_CONFIDENCE
  AMBIGUOUS_ADDRESS
  TICKET_CREATE_FAILED
  OTHER
}

enum EmailAutomationReviewStatus {
  PENDING
  RESOLVED
  DISMISSED
}

// Dispatch Intelligence (V1) — dispatch trade type, readiness, group lifecycle
enum DispatchTradeType {
  HANDYMAN
  PLUMBER
  HVAC
  ELECTRICIAN
  LOCKSMITH
  GENERAL_MAINTENANCE
}

enum DispatchReadiness {
  NOT_READY
  READY_FOR_DISPATCH
  WAITING_ON_DELIVERY
  WAITING_ON_APPROVAL
}

enum DispatchGroupStatus {
  DRAFT
  READY_TO_SEND
  SENT_TO_VENDOR
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// Lease IQ (V1) — per-studio lease responsibility rules and ticket evaluation
enum LeaseRuleSetStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LeaseSourceType {
  UPLOADED_PDF
  PASTED_EXTRACTION
}

enum LeaseRuleType {
  LANDLORD_RESPONSIBILITY
  TENANT_RESPONSIBILITY
  SHARED_OR_AMBIGUOUS
}

enum LeaseRuleTermType {
  KEYWORD
  PHRASE
  ALIAS
}

enum SuggestedResponsibility {
  LIKELY_LANDLORD
  LIKELY_TENANT
  NEEDS_HUMAN_REVIEW
}

enum LeaseIQResultState {
  RESOLVED
  AMBIGUOUS
  NO_MATCH
  NO_RULES_CONFIGURED
}

enum LeaseIQConfidence {
  HIGH
  MEDIUM
  LOW
}

enum EvaluationTrigger {
  CREATE
  MANUAL
  RULESET_UPDATE
}

// ============================================================
// ORGANIZATION STRUCTURE
// ============================================================

model Market {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studios   Studio[]
  tickets   Ticket[]
  users     User[]

  @@map("markets")
}

model Studio {
  id              String   @id @default(cuid())
  name            String
  marketId        String
  isActive        Boolean  @default(true)
  externalCode    String?  @unique
  formattedAddress String?
  latitude        Float?
  longitude       Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  market                   Market                    @relation(fields: [marketId], references: [id])
  tickets                  Ticket[]
  users                    User[]
  studioScopes             UserStudioScope[]
  studioAddressNormalized  StudioAddressNormalized[]
  leaseSources             LeaseSource[]
  leaseRuleSets            LeaseRuleSet[]
  dispatchGroupTemplatesAnchor DispatchGroupTemplate[]
  profile                  StudioProfile?

  @@unique([name, marketId])
  @@index([marketId])
  @@map("studios")
}

model StudioProfile {
  id        String   @id @default(cuid())
  studioId  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Operational attributes (public to all roles with access to the location page)
  district          String?
  status            String?
  maturity          String?
  studioSize        Int?
  priceTier         Int?
  openType          String?
  studioOpenDate    DateTime?
  rfSoftOpenDate    DateTime?

  // Ownership / team (restricted)
  dm                String?
  gm                String?
  agm               String?
  edc               String?
  li                String?

  // Contact info (restricted)
  studioEmail      String?
  gmEmail          String?
  gmTeams          String?
  liEmail          String?

  // Naming / system (restricted internal identifiers)
  studioCode       String?
  netsuiteName     String?
  ikismetName      String?
  crName           String?
  crId             String?
  paycomCode       String?

  studio Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@map("studio_profiles")
}

model Team {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  members     User[]
  subtasks    Subtask[]

  @@map("teams")
}

// ============================================================
// USERS
// ============================================================

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String
  avatarUrl   String?
  role        Role      @default(STUDIO_USER)
  teamId      String?
  studioId    String?
  marketId    String?
  ssoId        String?   @unique
  passwordHash String?
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  team        Team?     @relation(fields: [teamId], references: [id])
  studio      Studio?   @relation(fields: [studioId], references: [id])
  market      Market?   @relation(fields: [marketId], references: [id])

  submittedTickets    Ticket[]                 @relation("TicketRequester")
  ownedTickets        Ticket[]                 @relation("TicketOwner")
  comments            TicketComment[]
  mentions            CommentMention[]
  ownedSubtasks         Subtask[]
  assignedSubtaskTemplates SubtaskTemplate[]
  watchedTickets      TicketWatcher[]
  attachmentsUploaded  TicketAttachment[]
  notifications        Notification[]
  notificationPrefs    NotificationPreference[]
  auditLogs            AuditLog[]
  knowledgeDocs        KnowledgeDocument[]
  agentConversations   AgentConversation[]
  agentActionLogs      AgentActionLog[]
  departments          UserDepartment[]
  studioScopes         UserStudioScope[]
  dispatchGroupsCreated     DispatchGroup[]
  dispatchGroupTemplatesCreated DispatchGroupTemplate[]
  invitationsCreated   UserInvitation[] @relation("UserInvitationInviter")
  invitationRedeemed   UserInvitation?  @relation("UserInvitationRedeemed")

  @@index([email])
  @@index([role])
  @@index([teamId])
  @@map("users")
}

// ============================================================
// USER INVITATIONS (closed-system provisioning)
// ============================================================

model UserInvitation {
  id                   String           @id @default(cuid())
  emailNormalized      String           @map("email_normalized")
  invitedByUserId      String           @map("invited_by_user_id")
  tokenHash            String           @map("token_hash")
  /// AES-256-GCM wrap of raw 32-byte token (base64) so Resend can rebuild the same link without storing plaintext.
  tokenWrap            String           @map("token_wrap")
  tokenVersion         Int              @default(1) @map("token_version")
  status               InvitationStatus @default(PENDING)
  expiresAt            DateTime         @map("expires_at")
  acceptedAt           DateTime?        @map("accepted_at")
  revokedAt            DateTime?        @map("revoked_at")
  lastSentAt           DateTime?        @map("last_sent_at")
  sendCount            Int              @default(0) @map("send_count")
  resendWindowStartAt  DateTime?        @map("resend_window_start_at")
  resendsInWindow      Int              @default(0) @map("resends_in_window")
  assignedRole         Role             @map("assigned_role")
  seedName             String           @map("seed_name")
  departmentsJson      Json?            @map("departments_json")
  defaultStudioId      String?          @map("default_studio_id")
  additionalStudioIds  Json?            @map("additional_studio_ids")
  createdUserId        String?          @unique @map("created_user_id")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")

  invitedBy   User  @relation("UserInvitationInviter", fields: [invitedByUserId], references: [id])
  createdUser User? @relation("UserInvitationRedeemed", fields: [createdUserId], references: [id])

  @@index([tokenHash])
  @@index([emailNormalized])
  @@index([status])
  @@map("user_invitations")
}

// ============================================================
// USER DEPARTMENT MEMBERSHIPS
// ============================================================

model UserDepartment {
  userId     String
  department Department
  assignedAt DateTime   @default(now())
  assignedBy String?    // actorId of assigning ADMIN; null for system migration

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, department])
  @@index([userId])
  @@map("user_departments")
}

// ============================================================
// USER STUDIO SCOPE OVERRIDES
// ============================================================

model UserStudioScope {
  userId    String
  studioId  String
  grantedAt DateTime @default(now())
  grantedBy String?  // actorId of granting ADMIN; null for system migration

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  studio Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@id([userId, studioId])
  @@index([userId])
  @@map("user_studio_scopes")
}

// ============================================================
// TICKET TAXONOMY (Stage 2 config entities)
// ============================================================

model TicketClass {
  id        String   @id @default(cuid())
  code      String   @unique // SUPPORT | MAINTENANCE
  name      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets            Ticket[]
  formSchemas        TicketFormSchema[]
  workflowTemplates  SubtaskWorkflowTemplate[]

  @@map("ticket_classes")
}

/// Taxonomy departments (HR, OPERATIONS, MARKETING, RETAIL). Sync with Department enum for RBAC.
model TaxonomyDepartment {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  supportTopics     SupportTopic[]
  tickets           Ticket[]
  formSchemas       TicketFormSchema[]
  workflowTemplates SubtaskWorkflowTemplate[]
  subtaskTemplates  SubtaskTemplate[]
  subtasks          Subtask[]

  @@map("departments")
}

model SupportTopic {
  id           String   @id @default(cuid())
  departmentId String
  name         String
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department         TaxonomyDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  tickets            Ticket[]
  formSchemas        TicketFormSchema[]
  workflowTemplates  SubtaskWorkflowTemplate[]

  @@unique([departmentId, name])
  @@index([departmentId])
  @@map("support_topics")
}

model MaintenanceCategory {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tickets            Ticket[]
  formSchemas        TicketFormSchema[]
  workflowTemplates  SubtaskWorkflowTemplate[]
  leaseRules         LeaseRule[]
  dispatchGroupTemplates DispatchGroupTemplate[]

  @@map("maintenance_categories")
}

// ============================================================
// TICKET FORM SCHEMAS (Stage 3 — schema-driven forms)
// ============================================================

model TicketFormSchema {
  id                    String   @id @default(cuid())
  ticketClassId         String
  departmentId          String?
  supportTopicId        String?
  maintenanceCategoryId String?
  version               Int      @default(1)
  name                  String?
  sortOrder             Int      @default(0)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  ticketClass         TicketClass           @relation(fields: [ticketClassId], references: [id], onDelete: Cascade)
  department          TaxonomyDepartment?   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  supportTopic        SupportTopic?         @relation(fields: [supportTopicId], references: [id], onDelete: Cascade)
  maintenanceCategory MaintenanceCategory?  @relation(fields: [maintenanceCategoryId], references: [id], onDelete: Cascade)
  fields              TicketFormField[]

  @@unique([ticketClassId, supportTopicId])
  @@unique([ticketClassId, maintenanceCategoryId])
  @@index([ticketClassId])
  @@index([supportTopicId])
  @@index([maintenanceCategoryId])
  @@map("ticket_form_schemas")
}

model TicketFormField {
  id                  String   @id @default(cuid())
  formSchemaId        String
  fieldKey            String
  type                String   // text | textarea | select | checkbox | date | file
  label               String
  required            Boolean  @default(false)
  sortOrder           Int      @default(0)
  conditionalFieldKey String?
  conditionalValue    String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  formSchema TicketFormSchema    @relation(fields: [formSchemaId], references: [id], onDelete: Cascade)
  options    TicketFormFieldOption[]

  @@unique([formSchemaId, fieldKey])
  @@index([formSchemaId])
  @@map("ticket_form_fields")
}

model TicketFormFieldOption {
  id          String   @id @default(cuid())
  formFieldId String
  value       String
  label       String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  formField TicketFormField @relation(fields: [formFieldId], references: [id], onDelete: Cascade)

  @@index([formFieldId])
  @@map("ticket_form_field_options")
}

model TicketFormResponse {
  id        String   @id @default(cuid())
  ticketId  String
  fieldKey  String
  value     String
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@unique([ticketId, fieldKey])
  @@index([ticketId])
  @@map("ticket_form_responses")
}

// ============================================================
// TICKETS
// ============================================================

model Ticket {
  id                   String       @id @default(cuid())
  title                String
  description          String
  status               TicketStatus @default(NEW)
  priority             Priority     @default(MEDIUM)
  ticketClassId        String
  departmentId         String?
  supportTopicId       String?
  maintenanceCategoryId String?
  studioId             String?
  marketId             String?
  requesterId          String
  ownerId              String?
  dispatchTradeType    DispatchTradeType?
  dispatchReadiness    DispatchReadiness?
  resolvedAt           DateTime?
  closedAt             DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  ticketClass          TicketClass          @relation(fields: [ticketClassId], references: [id])
  department           TaxonomyDepartment?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  supportTopic         SupportTopic?       @relation(fields: [supportTopicId], references: [id], onDelete: SetNull)
  maintenanceCategory  MaintenanceCategory? @relation(fields: [maintenanceCategoryId], references: [id], onDelete: SetNull)
  studio               Studio?             @relation(fields: [studioId], references: [id])
  market               Market?             @relation(fields: [marketId], references: [id])
  requester            User                @relation("TicketRequester", fields: [requesterId], references: [id])
  owner                User?               @relation("TicketOwner", fields: [ownerId], references: [id])

  comments           TicketComment[]
  attachments        TicketAttachment[]
  subtasks           Subtask[]
  tags               TicketTag[]
  watchers           TicketWatcher[]
  notifications      Notification[]
  auditLogs          AuditLog[]
  formResponses      TicketFormResponse[]
  leaseIqResult      TicketLeaseIqResult?
  dispatchGroupItems DispatchGroupItem[]

  @@index([status])
  @@index([ownerId])
  @@index([requesterId])
  @@index([studioId])
  @@index([marketId])
  @@index([ticketClassId])
  @@index([departmentId])
  @@index([supportTopicId])
  @@index([maintenanceCategoryId])
  @@index([priority])
  @@index([createdAt])
  @@index([status, ownerId])
  @@index([requesterId, status])
  @@index([updatedAt])
  @@index([resolvedAt])
  @@index([studioId, dispatchTradeType, dispatchReadiness, status])
  @@map("tickets")
}

// ============================================================
// DISPATCH GROUPS (Dispatch Intelligence V1)
// ============================================================

model DispatchGroup {
  id         String              @id @default(cuid())
  tradeType  DispatchTradeType
  createdBy  String
  status     DispatchGroupStatus @default(DRAFT)
  targetDate DateTime?
  notes      String?
  vendorId   String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  creator User              @relation(fields: [createdBy], references: [id])
  items   DispatchGroupItem[]

  @@index([status])
  @@index([createdBy])
  @@index([createdAt])
  @@map("dispatch_groups")
}

model DispatchGroupItem {
  id                      String   @id @default(cuid())
  dispatchGroupId         String
  ticketId                String
  stopOrder               Int      @default(0)
  estimatedDurationMinutes Int?
  createdAt               DateTime @default(now())

  group  DispatchGroup @relation(fields: [dispatchGroupId], references: [id], onDelete: Cascade)
  ticket Ticket        @relation(fields: [ticketId], references: [id], onDelete: Restrict)

  @@unique([dispatchGroupId, ticketId])
  @@index([dispatchGroupId])
  @@index([ticketId])
  @@map("dispatch_group_items")
}

// ============================================================
// DISPATCH GROUP TEMPLATES (Grouping Workspace — rule-only, no ticket IDs)
// ============================================================

model DispatchGroupTemplate {
  id                    String             @id @default(cuid())
  name                  String
  createdBy             String
  dispatchTradeType     DispatchTradeType
  maintenanceCategoryId String?
  anchorStudioId        String?
  radiusMiles           Float
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  creator              User                 @relation(fields: [createdBy], references: [id])
  maintenanceCategory  MaintenanceCategory? @relation(fields: [maintenanceCategoryId], references: [id], onDelete: SetNull)
  anchorStudio         Studio?              @relation(fields: [anchorStudioId], references: [id], onDelete: SetNull)

  @@index([createdBy])
  @@index([dispatchTradeType])
  @@map("dispatch_group_templates")
}

// ============================================================
// COMMENTS + MENTIONS
// ============================================================

model TicketComment {
  id              String    @id @default(cuid())
  ticketId        String
  authorId        String
  body            String
  isInternal      Boolean   @default(false)
  parentCommentId String?
  editedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  ticket   Ticket           @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author   User             @relation(fields: [authorId], references: [id])
  parent   TicketComment?   @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies  TicketComment[]  @relation("CommentReplies")
  mentions CommentMention[]

  @@index([ticketId])
  @@index([authorId])
  @@index([ticketId, parentCommentId, createdAt, id])
  @@map("ticket_comments")
}

model CommentMention {
  id        String        @id @default(cuid())
  commentId String
  userId    String
  createdAt DateTime      @default(now())

  comment TicketComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id])

  @@unique([commentId, userId])
  @@index([userId])
  @@map("comment_mentions")
}

// ============================================================
// ATTACHMENTS
// ============================================================

model TicketAttachment {
  id           String   @id @default(cuid())
  ticketId     String
  uploadedById String
  filename     String
  mimeType     String
  sizeBytes    Int
  s3Key        String
  s3Bucket     String
  createdAt    DateTime @default(now())

  ticket     Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedBy User   @relation(fields: [uploadedById], references: [id])

  @@index([ticketId])
  @@map("ticket_attachments")
}

// ============================================================
// SUBTASK WORKFLOW (Stage 4 — template-driven, dependency-aware)
// ============================================================

/// One per ticket context (SUPPORT + supportTopicId or MAINTENANCE + maintenanceCategoryId).
model SubtaskWorkflowTemplate {
  id                    String   @id @default(cuid())
  ticketClassId         String
  departmentId          String?
  supportTopicId        String?
  maintenanceCategoryId String?
  name                  String?
  sortOrder             Int      @default(0)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  ticketClass         TicketClass           @relation(fields: [ticketClassId], references: [id], onDelete: Cascade)
  department          TaxonomyDepartment?   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  supportTopic        SupportTopic?        @relation(fields: [supportTopicId], references: [id], onDelete: Cascade)
  maintenanceCategory MaintenanceCategory? @relation(fields: [maintenanceCategoryId], references: [id], onDelete: Cascade)
  subtaskTemplates    SubtaskTemplate[]

  @@unique([ticketClassId, supportTopicId])
  @@unique([ticketClassId, maintenanceCategoryId])
  @@index([ticketClassId])
  @@index([supportTopicId])
  @@index([maintenanceCategoryId])
  @@map("subtask_workflow_templates")
}

model SubtaskTemplate {
  id                   String   @id @default(cuid())
  workflowTemplateId   String
  title                String
  description          String?
  departmentId         String
  assignedUserId       String?
  sortOrder            Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  workflowTemplate   SubtaskWorkflowTemplate @relation(fields: [workflowTemplateId], references: [id], onDelete: Cascade)
  department         TaxonomyDepartment     @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  assignedUser       User?                  @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  dependencyFrom     SubtaskTemplateDependency[] @relation("DependsOnTemplate")
  dependencyTo       SubtaskTemplateDependency[] @relation("RequiredByTemplate")
  liveSubtasks       Subtask[]

  @@index([workflowTemplateId])
  @@index([departmentId])
  @@map("subtask_templates")
}

/// Template A depends on template B: A cannot be READY until B is DONE/SKIPPED. DAG enforced on create.
model SubtaskTemplateDependency {
  subtaskTemplateId         String
  dependsOnSubtaskTemplateId String

  subtaskTemplate         SubtaskTemplate @relation("DependsOnTemplate", fields: [subtaskTemplateId], references: [id], onDelete: Cascade)
  dependsOnSubtaskTemplate SubtaskTemplate @relation("RequiredByTemplate", fields: [dependsOnSubtaskTemplateId], references: [id], onDelete: Cascade)

  @@id([subtaskTemplateId, dependsOnSubtaskTemplateId])
  @@map("subtask_template_dependencies")
}

/// Live dependency: subtaskId cannot be READY until dependsOnSubtaskId is DONE or SKIPPED.
model SubtaskDependency {
  subtaskId         String
  dependsOnSubtaskId String

  subtask          Subtask @relation("DependsOnSubtask", fields: [subtaskId], references: [id], onDelete: Cascade)
  dependsOnSubtask Subtask @relation("RequiredBySubtask", fields: [dependsOnSubtaskId], references: [id], onDelete: Cascade)

  @@id([subtaskId, dependsOnSubtaskId])
  @@index([dependsOnSubtaskId])
  @@map("subtask_dependencies")
}

// ============================================================
// SUBTASKS (live)
// ============================================================

model Subtask {
  id                 String        @id @default(cuid())
  ticketId           String
  teamId             String?
  ownerId            String?
  departmentId       String?
  subtaskTemplateId  String?
  title              String
  description        String?
  status             SubtaskStatus @default(READY)
  dueDate            DateTime?
  availableAt        DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  ticket          Ticket            @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  team            Team?             @relation(fields: [teamId], references: [id])
  owner           User?             @relation(fields: [ownerId], references: [id])
  department      TaxonomyDepartment? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  subtaskTemplate SubtaskTemplate?  @relation(fields: [subtaskTemplateId], references: [id], onDelete: SetNull)
  dependencyFrom  SubtaskDependency[] @relation("DependsOnSubtask")
  dependencyTo    SubtaskDependency[] @relation("RequiredBySubtask")

  @@index([ticketId])
  @@index([ticketId, status])
  @@index([ownerId])
  @@index([teamId])
  @@index([departmentId])
  @@index([departmentId, status])
  @@map("subtasks")
}

// ============================================================
// TAGS
// ============================================================

model Tag {
  id      String    @id @default(cuid())
  name    String    @unique
  color   String?
  tickets TicketTag[]

  @@map("tags")
}

model TicketTag {
  ticketId  String
  tagId     String
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([ticketId, tagId])
  @@map("ticket_tags")
}

// ============================================================
// WATCHERS
// ============================================================

model TicketWatcher {
  ticketId  String
  userId    String
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@id([ticketId, userId])
  @@index([userId])
  @@map("ticket_watchers")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String                @id @default(cuid())
  userId    String
  ticketId  String?
  eventType NotificationEventType
  title     String
  body      String
  metadata  Json?
  isRead    Boolean               @default(false)
  readAt    DateTime?
  createdAt DateTime              @default(now())

  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticket     Ticket?                @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  deliveries NotificationDelivery[]

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([ticketId])
  @@index([userId, ticketId, eventType, createdAt])
  @@map("notifications")
}

model NotificationDelivery {
  id             String          @id @default(cuid())
  notificationId String
  channel        DeliveryChannel
  status         DeliveryStatus  @default(PENDING)
  idempotencyKey String          @unique
  attemptCount   Int             @default(0)
  lastAttemptAt  DateTime?
  succeededAt    DateTime?
  failedAt       DateTime?
  errorMessage   String?
  externalId     String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([status, lastAttemptAt])
  @@index([notificationId])
  @@map("notification_deliveries")
}

model NotificationPreference {
  id              String                @id @default(cuid())
  userId          String
  eventType       NotificationEventType
  channelEmail    Boolean               @default(true)
  channelInApp    Boolean               @default(true)
  channelTeams    Boolean               @default(false)
  digestFrequency String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventType])
  @@index([userId])
  @@map("notification_preferences")
}

// ============================================================
// AI KNOWLEDGE BASE (pgvector RAG)
// ============================================================

model KnowledgeDocument {
  id               String    @id @default(cuid())
  title            String
  sourceType       String    @default("manual") // "manual" | "url" | "file"
  sourceUrl        String?
  s3Key            String?   // populated when sourceType = "file" (e.g. knowledge/<id>.pdf)
  mimeType         String?
  sizeBytes        Int?
  isActive         Boolean   @default(true)
  documentType     String?   @default("general") // "general" | "handbook"
  ingestionStatus  String    @default("pending") // pending | indexing | indexed | failed
  lastIndexedAt    DateTime?
  upstreamProvider String?   // e.g. "riser"
  upstreamId       String?   // e.g. Riser policy_id
  upstreamVersion  String?
  reviewOn         DateTime?
  reviewDue        DateTime?
  lastSyncedAt         DateTime?
  /// Increment when chunking or extraction logic changes; Riser sync re-ingests if below KNOWLEDGE_CHUNK_PIPELINE_VERSION.
  chunkPipelineVersion Int       @default(1)
  uploadedById         String
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  uploadedBy User            @relation(fields: [uploadedById], references: [id])
  chunks     DocumentChunk[]

  @@index([uploadedById])
  @@index([isActive])
  @@index([documentType])
  @@index([ingestionStatus])
  @@index([upstreamProvider, upstreamId])
  @@map("knowledge_documents")
}

model DocumentChunk {
  id         String   @id @default(cuid())
  documentId String
  chunkIndex Int
  content    String   // raw text of this chunk
  // embedding stored as pgvector — queried via $queryRaw
  embedding  Unsupported("vector(1536)")?
  tokenCount Int      @default(0)
  createdAt  DateTime @default(now())
  pageNumber Int?

  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_chunks")
}

// ============================================================
// AI AGENT (Conversations, Messages, Action Logs)
// ============================================================

model AgentConversation {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AgentMessage[]

  @@index([userId, isActive])
  @@index([createdAt])
  @@map("agent_conversations")
}

model AgentMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // "user" | "assistant" | "tool"
  content        String?
  toolCalls      Json?
  toolResults    Json?
  mode           String?  // "ASK" | "DO"
  actionPlan     Json?
  tokenCount     Int?
  createdAt      DateTime @default(now())

  conversation AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("agent_messages")
}

model AgentActionLog {
  id             String   @id @default(cuid())
  userId         String
  conversationId String?
  messageId      String?
  toolName       String
  toolArgs       Json
  resultSummary  String?
  success        Boolean
  errorMessage   String?
  executionMs    Int?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([conversationId])
  @@index([toolName])
  @@index([createdAt])
  @@map("agent_action_logs")
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id         String      @id @default(cuid())
  actorId    String
  action     AuditAction
  entityType String
  entityId   String
  ticketId   String?
  oldValues  Json?
  newValues  Json?
  metadata   Json?
  createdAt  DateTime    @default(now())

  actor  User    @relation(fields: [actorId], references: [id])
  ticket Ticket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([ticketId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================
// EMAIL AUTOMATION (Assembly ticket automation V1 — Stage 1)
// ============================================================

model InboundEmail {
  id                    String    @id @default(cuid())
  messageId             String    @unique // Gmail message id for dedupe
  threadId              String?
  historyId             String?
  subject               String?
  fromAddress           String?
  receivedAt            DateTime
  bodyPlain             String?
  bodyHtml              String?
  rawStorageRef         String?   // optional external storage ref for very large bodies
  classification        String?   // ORDER_CONFIRMATION | DELIVERY_CONFIRMATION | OTHER (filled in Stage 2+)
  classificationConfidence Float?
  processedAt           DateTime?
  createdAt             DateTime  @default(now())

  vendorOrderRecords    VendorOrderRecord[]
  deliveryEvents        DeliveryEvent[]
  reviewItems           EmailAutomationReviewItem[]
  automationEvents      EmailAutomationEvent[]

  @@index([receivedAt])
  @@index([processedAt])
  @@map("inbound_emails")
}

model VendorOrderRecord {
  id                      String           @id @default(cuid())
  orderNumber             String
  vendorIdentifier        String
  vendorDomain            String?          // e.g. amazon.com, petra.com
  shippingAddressRaw      String?
  shippingAddressNormalized String?
  emailId                 String
  state                   VendorOrderState  @default(ORDER_CONFIRMED)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  email       InboundEmail      @relation(fields: [emailId], references: [id], onDelete: Cascade)
  lineItems   OrderLineItem[]
  deliveryEvents DeliveryEvent[]
  reviewItems EmailAutomationReviewItem[]

  @@unique([orderNumber, vendorIdentifier])
  @@index([state])
  @@map("vendor_order_records")
}

model OrderLineItem {
  id         String   @id @default(cuid())
  orderId    String
  itemName   String
  quantity   Int      @default(1)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  order VendorOrderRecord @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_line_items")
}

model DeliveryEvent {
  id                String              @id @default(cuid())
  orderId           String?             // null when PENDING_ORDER_MATCH
  emailId           String
  deliveryTimestamp DateTime?
  deliverySource    String?             // e.g. carrier or "email"
  deliveryStatus    DeliveryEventStatus @default(DELIVERY_RECORDED)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  order  VendorOrderRecord? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  email  InboundEmail      @relation(fields: [emailId], references: [id], onDelete: Cascade)
  reviewItems EmailAutomationReviewItem[]

  @@index([orderId])
  @@index([emailId])
  @@index([deliveryStatus])
  @@map("delivery_events")
}

model StudioAddressNormalized {
  id               String   @id @default(cuid())
  studioId         String
  normalizedAddress String  // Street→St, lowercase, punctuation stripped
  createdAt        DateTime @default(now())

  studio Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@index([studioId])
  @@map("studio_address_normalized")
}

model AssemblyTriggerItem {
  id              String                 @id @default(cuid())
  keywordOrPhrase String
  displayName     String?
  matchMode       AssemblyTriggerMatchMode @default(SUBSTRING)
  isActive        Boolean                @default(true)
  sortOrder       Int                    @default(0)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([isActive])
  @@map("assembly_trigger_items")
}

model EmailAutomationReviewItem {
  id              String                     @id @default(cuid())
  emailId         String
  orderId         String?
  deliveryEventId String?
  reason          EmailAutomationReviewReason
  extractedPayload Json?
  status          EmailAutomationReviewStatus @default(PENDING)
  resolvedAt      DateTime?
  resolvedBy      String?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  email  InboundEmail       @relation(fields: [emailId], references: [id], onDelete: Cascade)
  order  VendorOrderRecord? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  deliveryEvent DeliveryEvent? @relation(fields: [deliveryEventId], references: [id], onDelete: SetNull)

  @@index([emailId])
  @@index([orderId])
  @@index([status])
  @@index([reason])
  @@map("email_automation_review_items")
}

model EmailAutomationEvent {
  id              String   @id @default(cuid())
  eventType       String
  emailId         String
  orderId         String?
  deliveryEventId String?
  payload         Json?
  createdAt       DateTime @default(now())

  email InboundEmail @relation(fields: [emailId], references: [id], onDelete: Cascade)

  @@index([emailId])
  @@index([orderId])
  @@index([eventType])
  @@index([createdAt])
  @@map("email_automation_events")
}

model EmailAutomationTicketCreated {
  orderNumber      String
  vendorIdentifier String
  ticketId         String
  createdAt        DateTime @default(now())

  @@id([orderNumber, vendorIdentifier])
  @@map("email_automation_ticket_created")
}

model EmailAutomationLock {
  id            String   @id @default(cuid())
  lockKey       String   @unique // orderNumber + vendor (e.g. "12345|amazon.com")
  acquiredAt    DateTime @default(now())
  expiresAt     DateTime
  releasedAt    DateTime?

  @@index([lockKey])
  @@index([expiresAt])
  @@map("email_automation_locks")
}

model EmailAutomationConfig {
  id                      String   @id @default(cuid())
  gmailLabel              String?  // e.g. INBOX or label name
  gmailPollWindowHours    Int      @default(24)
  gmailRefreshToken       String?  // OAuth2 refresh token (any @gmail.com; no Workspace required)
  gmailConnectedEmail     String?  // Email of connected Gmail account (for display)
  assemblyCategoryId      String?  // MaintenanceCategory id (for ticket create in later stage)
  systemRequesterId       String?  // User id (for ticket create in later stage)
  minOrderNumberConfidence Float   @default(0.8)
  minAddressConfidence    Float   @default(0.8)
  minItemConfidence       Float   @default(0.8)
  isEnabled               Boolean  @default(false)
  updatedAt               DateTime @updatedAt
  createdAt               DateTime @default(now())

  @@map("email_automation_config")
}

// ============================================================
// LEASE IQ (V1) — lease responsibility rules and ticket evaluation
// ============================================================

model LeaseSource {
  id               String         @id @default(cuid())
  studioId         String
  sourceType       LeaseSourceType
  rawText          String?         // extracted text for PDF; pasted text for PASTED_EXTRACTION
  fileStoragePath  String?
  originalFileName String?
  uploadedAt       DateTime       @default(now())
  uploadedByUserId String?

  studio Studio          @relation(fields: [studioId], references: [id], onDelete: Cascade)
  ruleSets LeaseRuleSet[]

  @@index([studioId, sourceType, uploadedAt])
  @@map("lease_sources")
}

model LeaseRuleSet {
  id                String            @id @default(cuid())
  studioId          String
  sourceId          String?           // FK to lease_sources; null for manually created rulesets
  status            LeaseRuleSetStatus
  createdAt         DateTime         @default(now())
  publishedAt       DateTime?
  publishedByUserId String?

  studio  Studio?       @relation(fields: [studioId], references: [id], onDelete: Cascade)
  source  LeaseSource?  @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  rules   LeaseRule[]
  ticketResults TicketLeaseIqResult[]

  @@index([studioId, status])
  @@map("lease_rule_sets")
}

model LeaseRule {
  id              String        @id @default(cuid())
  ruleSetId       String
  ruleType        LeaseRuleType
  categoryScope  String?       // maintenanceCategoryId or null = general
  clauseReference String?
  notes           String?
  priority        Int           @default(0) // higher = higher precedence
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  ruleSet         LeaseRuleSet        @relation(fields: [ruleSetId], references: [id], onDelete: Cascade)
  maintenanceCategory MaintenanceCategory? @relation(fields: [categoryScope], references: [id], onDelete: SetNull)
  terms          LeaseRuleTerm[]

  @@index([ruleSetId, ruleType, categoryScope])
  @@map("lease_rules")
}

model LeaseRuleTerm {
  id        String           @id @default(cuid())
  ruleId    String
  term      String
  termType  LeaseRuleTermType
  createdAt DateTime        @default(now())

  rule LeaseRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@map("lease_rule_terms")
}

model TicketLeaseIqResult {
  id                    String                 @id @default(cuid())
  ticketId              String                 @unique
  ruleSetId             String?
  suggestedResponsibility SuggestedResponsibility
  internalResultState   LeaseIQResultState?
  confidence            LeaseIQConfidence
  matchedRuleIds       String[]               // array of lease_rules.id
  matchedTerms         String[]              // matched term strings for display
  matchedCategory      String?                // maintenanceCategoryId if category-scoped match
  explanation          String
  evaluatedAt           DateTime              @default(now())
  evaluationTrigger     EvaluationTrigger

  ticket  Ticket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ruleSet LeaseRuleSet? @relation(fields: [ruleSetId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([ruleSetId])
  @@map("ticket_lease_iq_result")
}
